# Base URL of the Spec Server API.
VITE_API_BASE=http://localhost:8080

# Optional: a dev-only bearer token sent as `Authorization: Bearer <token>`.
# Only used when Cognito (below) is NOT configured. Leave unset for
# anonymous/local dev against an open server.
# VITE_DEV_TOKEN=

# --- Human sign-in (native Cognito WebAuthn passkeys + email-OTP) --------
# Leave ALL of these unset to run with no login flow (local-dev fallback:
# the dashboard behaves exactly as with VITE_DEV_TOKEN/no-auth above). The
# app talks DIRECTLY to the regional Cognito-IDP JSON API - no Amplify, no
# Hosted UI, no OAuth/PKCE redirect. Values must match the human native app
# client in infra/terraform/cognito.tf (`aws_cognito_user_pool_client.ui`).

# AWS region hosting the user pool. Defaults to eu-west-1 when unset.
# VITE_COGNITO_REGION=eu-west-1

# Cognito user pool ID, e.g. eu-west-1_AbCdEfGhI.
# VITE_COGNITO_USER_POOL_ID=

# Public native app client ID (no secret).
# VITE_COGNITO_CLIENT_ID=

# --- Admin console (HA-5-UI / UI-9) --------------------------------------
# Cognito group that gates the admin console (nav link + /admin route). The UI
# only shows it to members; the server re-checks the group on every admin call.
# Defaults to spec-admins; override to match a pool that renamed AUTH_GROUP_ADMIN.
# VITE_ADMIN_GROUP=spec-admins

# DNS-style domain the pool uses to synthesize agent usernames/emails
# (<slug>@<domain>), matching Terraform's agent_username_domain. Used to tell
# agent users apart from humans in the admin console. Defaults to
# agents.spec-server.internal.
# VITE_AGENT_EMAIL_DOMAIN=agents.spec-server.internal

# --- Public request-access page (HA-7, route /request) -------------------
# Cloudflare Turnstile site key. When set, the request-access form loads the
# Turnstile challenge script (https://challenges.cloudflare.com — allowed by the
# SPA's script-src + frame-src CSP), renders the widget, and forwards its token
# to /api/v1/signup as `turnstile_token`. Leave unset for local/dev to keep the
# build CSP-clean with no third-party script and no bot-gate.
# VITE_TURNSTILE_SITE_KEY=
