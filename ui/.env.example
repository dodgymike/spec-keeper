# Base URL of the Spec Server API.
VITE_API_BASE=http://localhost:8080

# Optional: a dev-only bearer token sent as `Authorization: Bearer <token>`.
# Only used when Cognito (below) is NOT configured. Leave unset for
# anonymous/local dev against an open server.
# VITE_DEV_TOKEN=

# --- Human sign-in (Cognito Hosted UI, Authorization Code + PKCE) ---------
# Leave ALL of these unset to run with no login flow (local-dev fallback:
# the dashboard behaves exactly as with VITE_DEV_TOKEN/no-auth above).
# Values must match the human SPA app client in infra/terraform/cognito.tf
# (`aws_cognito_user_pool_client.ui`) - see its `cognito_hosted_ui_domain`
# and `cognito_ui_client_id` outputs.

# Hosted-UI domain host, no scheme, e.g.
# spec-server-auth-ab12cd.auth.us-east-1.amazoncognito.com
# VITE_COGNITO_DOMAIN=

# Public SPA app client ID (no secret - PKCE proves possession instead).
# VITE_COGNITO_CLIENT_ID=

# Must exactly match one of the Cognito app client's allowed callback URLs.
# VITE_COGNITO_REDIRECT_URI=http://localhost:5173/callback

# Must exactly match one of the Cognito app client's allowed logout URLs.
# VITE_COGNITO_LOGOUT_URI=http://localhost:5173/

# VITE_COGNITO_SCOPES=openid email profile
