# Copy to .env and adjust. .env is gitignored.

# Postgres (used by docker-compose for the db service)
POSTGRES_USER=spec
POSTGRES_PASSWORD=spec
POSTGRES_DB=specserver

# SQLAlchemy connection string used by the Flask app.
# Inside docker-compose the host is the `db` service name.
DATABASE_URL=postgresql+psycopg://spec:spec@db:5432/specserver

# Storage adapter selected by app/storage/make_storage(). Both backends are
# implemented and behave identically (parity enforced by tests/test_parity.py):
# "postgres" (default, the reference adapter) or "dynamodb" (app/storage/dynamo.py).
# The dynamodb backend reads DYNAMODB_TABLE / DYNAMODB_ENDPOINT_URL / AWS_* straight
# from the environment (see README "Architecture").
STORAGE_BACKEND=postgres

# Default lease time-to-live for a claimed task, in seconds (30 min).
LEASE_DEFAULT_TTL=1800

# Optional comma-separated bearer tokens. If empty/unset, auth is disabled
# (fine for a local-only deployment). e.g. API_KEYS=alice-key,bob-key
API_KEYS=

# --- Cognito JWT auth (AUTH-2) ---------------------------------------------
# If COGNITO_ISSUER is set, it takes precedence over API_KEYS: every request
# must carry a valid Cognito RS256 JWT with the required scope. Leave unset to
# keep using API_KEYS (or no auth at all). Values come from terraform outputs
# in infra/terraform/cognito.tf (cognito_issuer_url, cognito_jwks_uri,
# cognito_m2m_client_ids / cognito_api_scope_identifiers).
COGNITO_ISSUER=
# Defaults to "<COGNITO_ISSUER>/.well-known/jwks.json" if unset.
COGNITO_JWKS_URI=
# Comma-separated accepted audiences/client_ids. Empty => audience check
# skipped (Cognito access tokens carry no `aud`, so `client_id` is also
# accepted). e.g. COGNITO_AUDIENCE=1example23client45id
COGNITO_AUDIENCE=
# Expected `token_use` claim on the JWT (Cognito M2M access tokens use "access").
COGNITO_TOKEN_USE=access
# JWKS cache TTL (seconds) and the minimum interval between refetches driven by
# an unknown `kid` (anti-DoS cooldown).
JWKS_CACHE_TTL=3600
JWKS_MIN_REFRESH_INTERVAL=30
# Clock-skew leeway (seconds) applied to exp/nbf checks.
AUTH_LEEWAY=0
# Required scope *names* per request type (matched against the token's `scope`
# claim, bare or as the full "<resource-server>/<name>" identifier).
AUTH_SCOPE_READ=tasks.read
AUTH_SCOPE_WRITE=tasks.write
AUTH_SCOPE_ADMIN=projects.admin

# --- CORS (AUTH-7) ----------------------------------------------------------
# Comma-separated exact-match allow-list of browser origins for the dashboard.
# Empty/unset => CORS disabled (local-only default). "*" is never honoured.
# e.g. CORS_ORIGINS=http://localhost:5173,https://app.spec-server.example.com
CORS_ORIGINS=
CORS_MAX_AGE=600
CORS_ALLOW_HEADERS=Authorization, Content-Type, If-Match, Idempotency-Key
CORS_ALLOW_METHODS=GET, HEAD, POST, PATCH, PUT, DELETE, OPTIONS

# --- Agent-side auth (client, not server) — used by scripts/agent_token.py -----
# Only needed to CALL a DEPLOYED server (one with COGNITO_ISSUER set); a local
# server has auth off, so leave these empty. These are agent CLIENT credentials,
# NOT server config — the server never needs a client secret at rest (it only
# validates JWTs via the public JWKS).
#
# The real client secret lives in AWS Secrets Manager (written by
# infra/terraform/cognito.tf, referenced by ARN — see output cognito_m2m_secret_arns),
# NEVER in this file, in tfvars, or in git. Prefer the ARN path below; the helper
# fetches client_id/client_secret/token_endpoint/scopes from that one secret.
AGENT_CLIENT_SECRET_ARN=
# ...or supply the fields inline for dev/CI (values from terraform outputs
# cognito_m2m_client_ids / cognito_token_endpoint / cognito_api_scope_identifiers).
# Do NOT paste a real client secret into a committed file; use a local .env only.
AGENT_CLIENT_ID=
AGENT_CLIENT_SECRET=
AGENT_TOKEN_ENDPOINT=
# Space-separated scopes to request, e.g.
# "https://api.spec-server/tasks.read https://api.spec-server/tasks.write"
AGENT_SCOPES=
