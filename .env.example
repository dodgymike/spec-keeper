# Copy to .env and adjust. .env is gitignored.

# Postgres (used by docker-compose for the db service)
POSTGRES_USER=spec
POSTGRES_PASSWORD=spec
POSTGRES_DB=specserver

# SQLAlchemy connection string used by the Flask app.
# Inside docker-compose the host is the `db` service name.
DATABASE_URL=postgresql+psycopg://spec:spec@db:5432/specserver

# Storage adapter selected by app/storage/make_storage(). Both backends are
# implemented and behave identically (parity enforced by tests/test_parity.py):
# "postgres" (default, the reference adapter) or "dynamodb" (app/storage/dynamo.py).
# The dynamodb backend reads DYNAMODB_TABLE / DYNAMODB_ENDPOINT_URL / AWS_* straight
# from the environment (see README "Architecture").
STORAGE_BACKEND=postgres

# Default lease time-to-live for a claimed task, in seconds (30 min).
LEASE_DEFAULT_TTL=1800

# Max request body in bytes (PORT-6). Above this, imports return a clean 413
# instead of a bare 500. Default 8 MiB comfortably fits a 2,000+ task SPEC.md.
MAX_CONTENT_LENGTH_BYTES=8388608

# Optional comma-separated bearer tokens. If empty/unset, auth is disabled
# (fine for a local-only deployment). e.g. API_KEYS=alice-key,bob-key
API_KEYS=

# --- Cognito JWT auth (AUTH-2 / AUTH-10) ------------------------------------
# If COGNITO_ISSUER is set, it takes precedence over API_KEYS: every request
# must carry a valid Cognito RS256 JWT, and the caller's Cognito GROUP
# membership must grant the required permission (see AUTH_GROUP_* below).
# Leave unset to keep using API_KEYS (or no auth at all). Values come from
# terraform outputs in infra/terraform/cognito.tf (cognito_issuer_url,
# cognito_jwks_uri, the agents + UI app-client ids).
COGNITO_ISSUER=
# Defaults to "<COGNITO_ISSUER>/.well-known/jwks.json" if unset.
COGNITO_JWKS_URI=
# Comma-separated accepted audiences/client_ids: the agents app-client id
# PLUS the UI app-client id. Empty => audience check skipped (Cognito access
# tokens carry no `aud`, so `client_id` is also accepted).
# e.g. COGNITO_AUDIENCE=1agentsclient23id,4uiclient56id
COGNITO_AUDIENCE=
# Expected `token_use` claim on the JWT (Cognito user-pool access tokens use "access").
COGNITO_TOKEN_USE=access
# JWKS cache TTL (seconds) and the minimum interval between refetches driven by
# an unknown `kid` (anti-DoS cooldown).
JWKS_CACHE_TTL=3600
JWKS_MIN_REFRESH_INTERVAL=30
# Clock-skew leeway (seconds) applied to exp/iat/nbf checks. Default 45 absorbs
# benign skew near token issuance so a just-minted token isn't spuriously 401'd.
AUTH_LEEWAY=45
# Claim carrying the caller's Cognito group list (a JSON list).
AUTH_GROUPS_CLAIM=cognito:groups
# Group names mapped to permission sets. A caller's effective permissions are
# the union over all groups it belongs to: spec-admins => read+write+admin,
# spec-writers => read+write, spec-readers => read. No matching group => no
# permissions (403 on anything needing read or above).
AUTH_GROUP_ADMIN=spec-admins
AUTH_GROUP_WRITE=spec-writers
AUTH_GROUP_READ=spec-readers

# --- Admin user lifecycle (HA-5) --------------------------------------------
# Cognito user pool the admin endpoints (GET/POST /api/v1/admin/users...) manage
# humans (and agents) in via cognito-idp admin actions (approve/reject/block/
# delete/promote). Unset (default) => those endpoints return 501, so a local run
# without a pool is graceful. Wired from the terraform output
# `cognito_user_pool_id` (infra/terraform/cognito.tf). AWS_REGION above is reused.
COGNITO_USER_POOL_ID=

# --- Invite-only human signup (HA-2) ----------------------------------------
# Dedicated DynamoDB table backing the admin invite endpoints (POST/GET
# /api/v1/admin/invites). Unset (default) => both endpoints return 501, so a
# local run without the table is graceful. Wired from the terraform output
# `invites_table_name` (infra/terraform/invites.tf).
INVITES_TABLE=
# Default validity window (days) for a freshly minted invite; overridable
# per-invite via the mint request's ttl_days (1-90).
INVITE_TTL_DAYS=14
# Base URL prefixed to the invite join_url returned by the mint endpoint
# (e.g. https://spec.example.com). Empty => a relative /join?code=... link.
INVITE_JOIN_BASE_URL=
# DYNAMODB_ENDPOINT_URL / AWS_REGION above are reused by the invites admin
# endpoints (via app/config.py) in addition to the dynamodb storage backend.

# --- Agent self-enrollment (ONBOARD-2/3) ------------------------------------
# The agent counterpart to invites: an admin mints a single-use enrollment
# token (POST /api/v1/admin/agent-enrollments); a brand-new agent redeems it
# once, PUBLIC/no-auth (POST /api/v1/agent-enrollments/redeem), which burns
# the token then provisions a real Cognito credential + project membership.
#
# Dedicated DynamoDB table backing the mint/list/revoke admin endpoints AND
# the public redeem endpoint. Unset (default) => all of them return 501, so a
# local run without the table is graceful. Wired from the terraform output
# `agent_enrollments_table_name`.
AGENT_ENROLLMENTS_TABLE=
# Default validity window (seconds) for a freshly minted enrollment token;
# overridable per-mint via the mint request's ttl_seconds (60-604800).
ENROLL_TTL_SECONDS=3600
# Base URL the mint endpoint's enrollment_url is built from (the plaintext
# token rides in the fragment, #token=...).
ENROLL_BASE_URL=https://spec.elasticninja.com
# API base URL the redeem endpoint hands back in its response/recipe, so a
# newly-enrolled agent knows where to call.
ENROLL_API_BASE=https://api.spec.elasticninja.com
# Cognito app-client id (USER_PASSWORD_AUTH, no client secret). Used two ways
# (ONBOARD-8): the SERVER signs the new agent in itself against this client to
# return a ready access_token, AND the redeem response tells the agent to re-auth
# against it when that token expires. Unset => the server skips server-side
# sign-in (falls back to returning raw creds + a note) and omits it from the
# recipe. Wired from terraform.
ENROLL_COGNITO_CLIENT_ID=
# Email-as-username domain for agent sign-in aliases: redeem provisions a
# project-namespaced <sanitized-agent-name>.<sanitized-project-slug>.<16-hex-
# digest>@<ENROLL_AGENT_DOMAIN> (ONBOARD-3a) so the same agent_name in
# different projects gets a different Cognito user. The 19 platform agents
# provisioned by scripts/enrol_agents.py still use the plain
# <name>@<ENROLL_AGENT_DOMAIN> scheme and are unaffected.
ENROLL_AGENT_DOMAIN=agents.spec-server.internal
# COGNITO_USER_POOL_ID above is reused by redeem's provisioning step.

# --- Public request->approve signup queue (HA-7) ----------------------------
# The public self-service path: POST /api/v1/signup (uniform-202 anti-
# enumeration intake, PUBLIC/no-auth) -> SQS -> async worker -> GET
# /api/v1/validate magic-link redeem (PUBLIC/no-auth) -> admin approve
# (/api/v1/admin/signups*) -> provision (mints an HA-2 invite + SES's the join
# link). Every knob below is unset by default so a local run degrades
# gracefully: intake still 202s without enqueuing, validate returns the
# neutral "invalid", and the admin endpoints 501 (mirrors INVITES_TABLE above).
#
# Dedicated signups DynamoDB table. Wired from terraform output
# `signups_table_name` (infra/terraform/signups.tf).
SIGNUPS_TABLE=
# SQS intake queue URL the public POST /signup enqueues to. Wired from
# terraform output `signup_intake_queue_url`.
SIGNUP_INTAKE_QUEUE_URL=
# Endpoint override for the SQS client (e.g. a local SQS emulator). Unset =>
# boto3 talks to real AWS.
SQS_ENDPOINT_URL=
# Per-IP fixed-window rate-limit counter table for the public signup routes.
# Wired from terraform output `signup_ratelimit_table_name`. Unset => the
# in-app limiter fails open (the CDN/edge limiter is the durable backstop).
SIGNUP_RATELIMIT_TABLE=
SIGNUP_RATELIMIT_MAX=5
SIGNUP_RATELIMIT_WINDOW_S=60
# SEC-DOS-2 — per-authenticated-principal (per Cognito `sub`) API throttle. A
# per-`sub` fixed-window limit enforced AFTER the JWT is verified, on the
# /api/v1 data-plane, so one token/tenant cannot starve the single stage-wide
# API Gateway budget shared across all tokens. Keyed ONLY on the verified `sub`
# (never client input). Reuses the signup-ratelimit DynamoDB table (distinct
# `apisub#` key namespace) — no new infra/IAM. FAILS OPEN: unset table OR any
# DynamoDB error => the request is ALLOWED (never 429 a legit agent). Global
# spec-admins are exempt. Defaults are generous (120 req / 10 s per sub).
API_RATELIMIT_TABLE=
API_RATELIMIT_MAX=120
API_RATELIMIT_WINDOW_S=10
# Cloudflare Turnstile server-side secret. Set => POST /signup verifies the
# submitted turnstile_token server-side (a failed/absent token is dropped as a
# bot, still returning the uniform 202). Unset (dev default) => skipped. Sensitive.
TURNSTILE_SECRET=
# Optional pepper for email_hash (HMAC-SHA256 instead of a plain SHA-256),
# defeating offline dictionary reversal of a leaked signups table. MUST match
# the signup worker Lambda. Unset => a plain SHA-256 hash (fine for dev). Sensitive.
SIGNUP_PEPPER=
# Base URL the signup worker prefixes to the magic-link validation URL it
# emails (e.g. https://spec.elasticninja.com). Empty => a relative link.
SIGNUP_VALIDATE_BASE_URL=
# When true AND SIGNUP_ALLOWED_ORIGINS is non-empty, POST /signup requires the
# Origin/Referer to match one of the allowed origins, else 403. Off by default.
SIGNUP_ENFORCE_ORIGIN=false
# Comma-separated exact-match origin allow-list, used only when
# SIGNUP_ENFORCE_ORIGIN=true, e.g. https://spec.elasticninja.com.
SIGNUP_ALLOWED_ORIGINS=
# Verified SES sender address + configuration set (reused from the HA-6
# transactional-email setup) for the signup-approve join-link email. Unset =>
# the send is skipped (logged); approve still provisions, just without an email.
SES_FROM_ADDRESS=
SES_CONFIG_SET=

# --- CORS (AUTH-7) ----------------------------------------------------------
# Comma-separated exact-match allow-list of browser origins for the dashboard.
# Empty/unset => CORS disabled (local-only default). "*" is never honoured.
# e.g. CORS_ORIGINS=http://localhost:5173,https://app.spec-server.example.com
CORS_ORIGINS=
CORS_MAX_AGE=600
CORS_ALLOW_HEADERS=Authorization, Content-Type, If-Match, Idempotency-Key
CORS_ALLOW_METHODS=GET, HEAD, POST, PATCH, PUT, DELETE, OPTIONS

# --- Agent-side auth (client, not server) — used by scripts/agent_token.py -----
# Only needed to CALL a DEPLOYED server (one with COGNITO_ISSUER set); a local
# server has auth off, so leave these empty. Agents authenticate as Cognito
# USERS via USER_PASSWORD_AUTH against the "agents" app client (no client
# secret) — the old M2M client_credentials clients were retired.
#
# Agent credentials live in the "agent-credentials" AWS Secrets Manager secret,
# JSON shaped:
#   {"pool_id": "...", "client_id": "...", "region": "us-east-1",
#    "users": {"<name>": {"password": "...", "groups": ["spec-writers"]}}}
# NEVER paste a real password into this file, in tfvars, or in git. Prefer the
# ARN path below; the helper fetches pool_id/client_id/region/password from
# that one secret and selects the user via AGENT_USERNAME.
AGENT_CREDENTIALS_SECRET_ARN=
# ...or supply the fields inline for dev/CI, as an alternative to the ARN.
# Env values override the corresponding secret fields.
AGENT_USERNAME=
AGENT_PASSWORD=
COGNITO_CLIENT_ID=
COGNITO_REGION=
# Fernet encryption key(s) for Jira API token storage (JIRA integration).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Note: Jira connection details (base_url, email, project_key, enabled) are stored per-project
# in the database via POST /projects/{slug}/jira-config — NOT as env vars. This key is the only
# env-level config needed for Jira; it encrypts the API tokens at rest in the DB.
# SEC-FIX-12: may be a SINGLE key or a COMMA-SEPARATED list. With a list the FIRST
# key is primary (encrypts) and ALL keys can decrypt (MultiFernet) — this is how a
# zero-downtime rotation works: prepend the new key, re-encrypt lazily, then drop
# the retired one. Both this and the ARN below UNSET => encrypt/decrypt fail closed.
JIRA_TOKEN_ENCRYPTION_KEY=
# SEC-FIX-12: production alternative to the bare key above. When set, the key
# material is loaded ONCE (and cached in-process) from this AWS Secrets Manager
# secret (CMK-encrypted, like agent-credentials) and the raw JIRA_TOKEN_ENCRYPTION_KEY
# is ignored. The secret's value has the SAME format (single key or comma-separated
# list). Leave UNSET for local/dev (the env var above is the fallback). The Lambda
# needs secretsmanager:GetSecretValue on THIS arn — see DECISIONS.md (deferred
# terraform, provisioned only when Jira is enabled in prod).
JIRA_TOKEN_ENCRYPTION_KEY_SECRET_ARN=
# SSRF guard (SEC-FIX-1): allow-list of host suffixes a project's Jira base_url may
# target (comma-separated). The server calls base_url server-side, so an
# unvalidated value is an authenticated SSRF primitive. Default is Jira Cloud
# (.atlassian.net). Override ONLY to deliberately permit a self-hosted Jira host,
# e.g. JIRA_ALLOWED_HOST_SUFFIXES=.atlassian.net,.jira.mycorp.com . Regardless of
# this list, https is required and private/loopback/link-local IP literals (and
# localhost) are always rejected.
JIRA_ALLOWED_HOST_SUFFIXES=.atlassian.net
